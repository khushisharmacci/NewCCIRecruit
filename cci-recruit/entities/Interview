{
  "name": "Interview",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Tenant company ID for data isolation"
    },
    "candidate_name": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string"
    },
    "position": {
      "type": "string"
    },
    "interviewer": {
      "type": "string"
    },
    "interview_date": {
      "type": "string",
      "format": "date"
    },
    "interview_time": {
      "type": "string"
    },
    "interview_type": {
      "type": "string",
      "enum": [
        "Online",
        "Offline"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Scheduled",
        "Completed",
        "Selected",
        "Rejected",
        "On Hold"
      ],
      "default": "Scheduled"
    },
    "feedback": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "rating": {
      "type": "number"
    },
    "location": {
      "type": "string"
    }
  },
  "required": [
    "candidate_name",
    "candidate_id",
    "interview_date",
    "status"
  ]
}