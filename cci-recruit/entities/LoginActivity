{
  "name": "LoginActivity",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Tenant company ID for data isolation"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "user_role": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "login",
        "logout",
        "failed_login",
        "password_reset",
        "role_change"
      ]
    },
    "ip_address": {
      "type": "string"
    },
    "device_info": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed"
      ],
      "default": "success"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "user_email",
    "action"
  ]
}