{
  "name": "RevenueRecord",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Tenant company ID for data isolation"
    },
    "client_name": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "recruiter_name": {
      "type": "string"
    },
    "candidate_name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "Placement Fee",
        "Retainer",
        "Contract",
        "Consulting",
        "Other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Received",
        "Overdue"
      ],
      "default": "Pending"
    },
    "invoice_number": {
      "type": "string"
    }
  },
  "required": [
    "client_name",
    "amount",
    "date"
  ]
}