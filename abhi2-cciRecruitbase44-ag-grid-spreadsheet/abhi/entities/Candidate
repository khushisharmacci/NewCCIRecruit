{
  "name": "Candidate",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Tenant company ID for data isolation"
    },
    "full_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string"
    },
    "skills": {
      "type": "string"
    },
    "experience_years": {
      "type": "number"
    },
    "current_company": {
      "type": "string"
    },
    "current_role": {
      "type": "string"
    },
    "expected_salary": {
      "type": "number"
    },
    "location": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Applied",
        "Screening",
        "Shortlisted",
        "Interview Scheduled",
        "Selected",
        "Offer Released",
        "Joined",
        "Rejected",
        "On Hold"
      ],
      "default": "Applied"
    },
    "resume_url": {
      "type": "string"
    },
    "resume_filename": {
      "type": "string"
    },
    "resume_upload_date": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "LinkedIn",
        "Job Board",
        "Referral",
        "Direct",
        "Agency",
        "Other"
      ]
    },
    "assigned_to": {
      "type": "string"
    },
    "position_title": {
      "type": "string"
    },
    "photo_url": {
      "type": "string"
    },
    "spreadsheet_id": {
      "type": "string",
      "description": "Linked DataFile ID for two-way sync"
    },
    "spreadsheet_row_id": {
      "type": "string",
      "description": "Unique row identifier within the linked spreadsheet"
    }
  },
  "required": [
    "full_name",
    "email",
    "status"
  ]
}