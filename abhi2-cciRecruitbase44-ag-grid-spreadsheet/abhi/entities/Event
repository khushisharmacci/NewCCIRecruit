{
  "name": "Event",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Tenant company ID for data isolation"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "Interview",
        "Follow-Up",
        "Resume Review",
        "Candidate Submission",
        "Offer Release",
        "Joining Date",
        "Candidate Documentation",
        "Client Meeting",
        "Client Follow-Up",
        "Requirement Deadline",
        "Contract Renewal",
        "Agreement Expiry",
        "Attendance Approval",
        "Leave Approval",
        "Performance Review",
        "Team Meeting",
        "Task",
        "Reminder",
        "Note",
        "Personal Follow-Up",
        "Revenue Review",
        "Monthly Report",
        "KPI Review",
        "Executive Meeting"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "Critical",
        "High",
        "Medium",
        "Low"
      ],
      "default": "Medium"
    },
    "status": {
      "type": "string",
      "enum": [
        "Upcoming",
        "In Progress",
        "Completed",
        "Missed",
        "Cancelled",
        "Overdue"
      ],
      "default": "Upcoming"
    },
    "start_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "end_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "all_day": {
      "type": "boolean",
      "default": false
    },
    "location": {
      "type": "string"
    },
    "owner_name": {
      "type": "string"
    },
    "owner_id": {
      "type": "string"
    },
    "assigned_to": {
      "type": "string"
    },
    "team": {
      "type": "string"
    },
    "department": {
      "type": "string"
    },
    "related_candidate": {
      "type": "string"
    },
    "related_client": {
      "type": "string"
    },
    "reminders": {
      "type": "string",
      "description": "JSON array of reminder offsets in minutes"
    },
    "reminder_sent": {
      "type": "boolean",
      "default": false
    },
    "escalation_level": {
      "type": "number",
      "default": 0
    },
    "color": {
      "type": "string"
    },
    "recurrence": {
      "type": "string",
      "enum": [
        "None",
        "Daily",
        "Weekly",
        "Monthly"
      ],
      "default": "None"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "event_type",
    "start_datetime"
  ]
}