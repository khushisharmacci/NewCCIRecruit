{
  "name": "AttendanceRecord",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Tenant company ID for data isolation"
    },
    "employee_name": {
      "type": "string"
    },
    "employee_id": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "check_in": {
      "type": "string"
    },
    "check_out": {
      "type": "string"
    },
    "total_hours": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "Present",
        "Absent",
        "Half Day",
        "Late"
      ],
      "default": "Present"
    },
    "work_mode": {
      "type": "string",
      "enum": [
        "WFO",
        "WFH"
      ],
      "default": "WFO"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "employee_name",
    "date"
  ]
}