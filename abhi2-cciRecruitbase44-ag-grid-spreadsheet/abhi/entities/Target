{
  "name": "Target",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Tenant company ID for data isolation"
    },
    "recruiter_name": {
      "type": "string"
    },
    "period": {
      "type": "string",
      "enum": [
        "Daily",
        "Weekly",
        "Monthly",
        "Quarterly",
        "Yearly"
      ]
    },
    "target_type": {
      "type": "string",
      "enum": [
        "Placements",
        "Interviews",
        "Screenings",
        "Revenue",
        "Closures"
      ]
    },
    "target_value": {
      "type": "number"
    },
    "achieved_value": {
      "type": "number",
      "default": 0
    },
    "start_date": {
      "type": "string",
      "format": "date-time"
    },
    "end_date": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "recruiter_name",
    "period",
    "target_type",
    "target_value"
  ]
}